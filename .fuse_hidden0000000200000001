// Niveau précédent requis pour déverrouiller chaque niveau
const PREREQUIS = {
  debutant:      null,          // toujours débloqué
  intermediaire: "debutant",
  avance:        "intermediaire",
};

// Retourne true si le niveau est accessible pour ce thème
function estDebloque(themeCle, niveauCle) {
  const prerequis = PREREQUIS[niveauCle];
  if (!prerequis) return true; // Débutant toujours ouvert
  const prog = chargerProgression();
  return !!(prog[themeCle]?.[prerequis]); // débloqué si le niveau précédent a été joué au moins une fois
}

